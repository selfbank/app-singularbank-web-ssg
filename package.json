    "husky": "^9.1.7",
    "include-media": "^1.4.10",
    "jquery": "^3.7.1",
    "modularscale-sass": "^3.0.10",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1",
    "sass": "^1.99.0",
    "typi": "^3.2.0"
